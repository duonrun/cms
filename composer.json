{
	"name": "celemas/cms",
	"description": "Celemas content management system and framework",
	"type": "library",
	"license": "MIT",
	"authors": [
		{
			"name": "Ernst",
			"email": "ernst@celemas.dev"
		}
	],
	"homepage": "https://celemas.dev/cms",
	"minimum-stability": "dev",
	"prefer-stable": true,
	"require": {
		"php": "^8.5",
		"ext-pgsql": "*",
		"ext-gd": "*",
		"ext-intl": "*",
		"ext-curl": "*",
		"ext-dom": "*",
		"ext-xml": "*",
		"celemas/boiler": "^0.3.3",
		"celemas/core": "dev-main",
		"celemas/error": "^0.1",
		"celemas/quma": "dev-main",
		"celemas/session": "dev-main",
		"celemas/sire": "dev-main",
		"gumlet/php-image-resize": "2.0.*",
		"hidehalo/nanoid-php": "^2",
		"psr/log": "^3.0",
		"vlucas/phpdotenv": "^5.6"
	},
	"require-dev": {
		"celemas/dev": "^4.1",
		"filp/whoops": "^2.15",
		"laminas/laminas-diactoros": "^3"
	},
	"suggest": {
		"filp/whoops": "Enables pretty debug error pages in debug mode."
	},
	"autoload": {
		"psr-4": {
			"Celemas\\Cms\\": "src"
		},
		"files": [
			"src/Functions.php"
		]
	},
	"autoload-dev": {
		"psr-4": {
			"Celemas\\Cms\\Tests\\": "tests"
		}
	},
	"scripts": {
		"test": "./vendor/bin/phpunit --testdox --no-coverage --colors=always",
		"docs:format": "npx prettier@3.6.2 --write --config ./docs/.prettierrc README.md CHANGELOG.md LICENSE.md",
		"docs:lint": "npx markdownlint-cli2@0.22.1 --config ./vendor/celemas/dev/config/markdownlint.jsonc README.md CHANGELOG.md LICENSE.md",
		"lint": [
			"./vendor/bin/mago fmt --check",
			"./vendor/bin/mago lint"
		],
		"coverage": [
			"php -d xdebug.mode=coverage ./vendor/bin/phpunit --testdox --path-coverage --coverage-text --coverage-php=.coverage/cover.php --colors=always",
			"./vendor/bin/coverlyzer .coverage/cover.php"
		],
		"ci": [
			"composer lint",
			"composer coverage",
			"composer docs:lint"
		]
	}
}
